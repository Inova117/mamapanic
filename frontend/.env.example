# ==================== SUPABASE CONFIGURATION ====================
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
# Example format shown below:

# Project URL - Found in Project Settings → API
# Format: https://abcdefghijklmnop.supabase.co
EXPO_PUBLIC_SUPABASE_URL=https://xyzabcdefghijk.supabase.co

# Anon Public Key - Found in Project Settings → API → Project API keys → anon public
# This is safe to use in the frontend (starts with "eyJ")
# Format: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOi...
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inh5emFiY2RlZmdoaWprIiwicm9sZSI6ImFub24iLCJpYXQiOjE2NDE1OTc0ODAsImV4cCI6MTk1NzE3MzQ4MH0.example_signature_here

# ==================== GROQ AI CONFIGURATION ====================
# Groq is SERVER-SIDE only. The app calls the `groq-proxy` Edge Function; the
# key is NEVER in the client bundle. Do NOT add EXPO_PUBLIC_GROQ_API_KEY.
# Set the secret instead:  supabase secrets set GROQ_API_KEY=gsk_xxx

# ==================== SENTRY CONFIGURATION ====================
# Get this from: https://sentry.io/settings/YOUR_ORG/projects/YOUR_PROJECT/keys/
# Used for error tracking and performance monitoring

# Sentry DSN - Found in Project Settings → Client Keys (DSN)
# Format: https://public_key@o123456.ingest.sentry.io/project_id
EXPO_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0000000.ingest.sentry.io/0000000

# Sentry Environment (development, staging, production)
EXPO_PUBLIC_SENTRY_ENVIRONMENT=development

# Enable Sentry in production only (true/false)
EXPO_PUBLIC_SENTRY_ENABLED=false

# ==================== EXPO CONFIGURATION ====================
# Expo configuration for development

# Use fast resolver for better performance
EXPO_USE_FAST_RESOLVER="1"

# Optional: Custom tunnel subdomain for Expo (for development)
# EXPO_TUNNEL_SUBDOMAIN=mamapanic
